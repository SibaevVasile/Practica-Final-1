<Page x:Class="InventarIT.Views.EchipamentView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Echipamente">

    <DockPanel Margin="10">

        <!-- Titlu -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Gestionare Echipamente"
                   FontSize="20" FontWeight="Bold"
                   Margin="0,0,0,10" Foreground="#2C3E50"/>

        <!-- Bara de actiuni -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    Margin="0,10,0,0">
            <Button Content="➕ Adaugă"   Width="110" Height="35"
                    Margin="0,0,8,0" Background="#27AE60"
                    Foreground="White" FontSize="13"/>
            <Button Content="✏️ Modifică" Width="110" Height="35"
                    Margin="0,0,8,0" Background="#2980B9"
                    Foreground="White" FontSize="13"/>
            <Button Content="🗑️ Șterge"   Width="110" Height="35"
                    Background="#E74C3C"
                    Foreground="White" FontSize="13"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid x:Name="dgEchipamente"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  AlternatingRowBackground="#F9F9F9"
                  RowBackground="White"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  SelectionMode="Single">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                    Binding="{Binding IdEchipament}" Width="45"/>
                <DataGridTextColumn Header="Denumire"
                    Binding="{Binding Denumire}"     Width="180"/>
                <DataGridTextColumn Header="Tip"
                    Binding="{Binding Tip}"          Width="100"/>
                <DataGridTextColumn Header="Nr. Serie"
                    Binding="{Binding NumarSerie}"   Width="120"/>
                <DataGridTextColumn Header="Producător"
                    Binding="{Binding Producator}"   Width="110"/>
                <DataGridTextColumn Header="Valoare"
                    Binding="{Binding ValoareFormatata}" Width="100"/>
                <DataGridTextColumn Header="Status"
                    Binding="{Binding Status}"       Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Page>