<Page x:Class="InventarIT.Views.AngajatView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Angajati">

    <DockPanel Margin="15">

        <!-- Titlu -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Gestionare Angajați"
                   FontSize="22" FontWeight="Bold"
                   Foreground="#2C3E50" Margin="0,0,0,12"/>

        <!-- Bara cautare -->
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Căutare:" VerticalAlignment="Center"
                       FontSize="13" Margin="0,0,8,0"/>
            <TextBox x:Name="txtCautare" Width="250" Height="30"
                     FontSize="13" Padding="5,3"
                     TextChanged="txtCautare_TextChanged"/>
            <TextBlock Text="(după Nume sau Email)"
                       VerticalAlignment="Center"
                       Foreground="Gray" FontSize="11"
                       Margin="8,0,0,0"/>
        </StackPanel>

        <!-- Butoane actiuni -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal" Margin="0,10,0,0">
            <Button x:Name="btnAdauga" Content="➕ Adaugă"
                    Width="120" Height="35" Margin="0,0,8,0"
                    Background="#27AE60" Foreground="White"
                    FontSize="13" Click="btnAdauga_Click"/>
            <Button x:Name="btnModifica" Content="✏️ Modifică"
                    Width="120" Height="35" Margin="0,0,8,0"
                    Background="#2980B9" Foreground="White"
                    FontSize="13" Click="btnModifica_Click"/>
            <Button x:Name="btnSterge" Content="🗑️ Șterge"
                    Width="120" Height="35"
                    Background="#E74C3C" Foreground="White"
                    FontSize="13" Click="btnSterge_Click"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid x:Name="dgAngajati"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  AlternatingRowBackground="#F5F6FA"
                  RowBackground="White"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  SelectionMode="Single"
                  FontSize="13">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                    Binding="{Binding IdAngajat}"
                    Width="45"/>
                <DataGridTextColumn Header="Nume"
                    Binding="{Binding Nume}"
                    Width="130"/>
                <DataGridTextColumn Header="Prenume"
                    Binding="{Binding Prenume}"
                    Width="130"/>
                <DataGridTextColumn Header="Departament"
                    Binding="{Binding Departament}"
                    Width="130"/>
                <DataGridTextColumn Header="Email"
                    Binding="{Binding Email}"
                    Width="200"/>
                <DataGridTextColumn Header="Telefon"
                    Binding="{Binding Telefon}"
                    Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Page>