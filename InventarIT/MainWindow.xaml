<Window x:Class="InventarIT.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="InventarIT — Sistem de Gestionare Inventar"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen">

    <DockPanel>
        <!-- Meniu navigare top -->
        <Menu DockPanel.Dock="Top" Background="#2C3E50" Height="45">
            <MenuItem Header="🖥 Echipamente"
                      Foreground="White" FontSize="14"
                      Click="NavigateEchipamente"/>
            <MenuItem Header="👤 Angajați"
                      Foreground="White" FontSize="14"
                      Click="NavigateAngajati"/>
            <MenuItem Header="🔗 Atribuiri"
                      Foreground="White" FontSize="14"
                      Click="NavigateAtribuiri"/>
            <MenuItem Header="📊 Raport"
                      Foreground="White" FontSize="14"
                      Click="NavigateRaport"/>
        </Menu>

        <!-- Header aplicatie -->
        <StackPanel DockPanel.Dock="Top" 
                    Background="#34495E" Height="50"
                    Orientation="Horizontal">
            <TextBlock Text="📦 InventarIT" 
                       Foreground="White" FontSize="20"
                       FontWeight="Bold" Margin="20,12,0,0"/>
            <TextBlock x:Name="txtModulActiv"
                       Foreground="#BDC3C7" FontSize="14"
                       Margin="15,16,0,0" Text="— Selectați un modul"/>
        </StackPanel>

        <!-- Zona continut principal -->
        <Frame x:Name="MainFrame"
               NavigationUIVisibility="Hidden"/>
    </DockPanel>
</Window>